{
  "manifest_version": 3,
  "name": "OmniDraft",
  "version": "1.0.0",
  "description": "A universal, context-aware writing assistant powered entirely by your local device.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_end"
    }
  ]
}