{
  "manifest_version": 3,
  "name": "OmniDraft",
  "version": "2.0.0",
  "description": "Polish any text field in place using a local, on-device AI model. Press Ctrl+Shift+Y to rewrite. Hold the modifier shown in settings for a preview before applying.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "settings.html",
    "default_title": "OmniDraft settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
